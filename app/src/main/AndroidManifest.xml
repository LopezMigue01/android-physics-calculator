<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/icono"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/icono"
        android:supportsRtl="true"
        android:theme="@style/Theme.Proyecto_Fisica"
        tools:targetApi="31">
        <activity
            android:name=".ResultadoCalcuActivity"
            android:exported="false"
            android:theme="@style/Theme.Proyecto_Fisica.NoActionBar" />
        <activity
            android:name=".CalculadoraActivity"
            android:exported="false"
            android:theme="@style/Theme.Proyecto_Fisica.NoActionBar" />
        <activity
            android:name=".MenuCuestionario"
            android:exported="false"
            android:theme="@style/Theme.Proyecto_Fisica.NoActionBar" />
        <activity
            android:name=".IniciarSesion"
            android:exported="false"
            android:theme="@style/Theme.Proyecto_Fisica.NoActionBar" />
        <activity
            android:name=".CrearCuenta"
            android:exported="false"
            android:theme="@style/Theme.Proyecto_Fisica.NoActionBar" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Proyecto_Fisica.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>