<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".CalculadoraActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DDE2E8"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/anton"
            android:text="CALCULADORA"
            android:textColor="#C6A828"
            android:textAlignment="center"
            android:textSize="34sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Formula:"
                    android:textColor="#006A7C"
                    android:textAlignment="center"
                    android:textSize="24sp" />

                <Spinner
                    android:spinnerMode="dropdown"
                    android:id="@+id/xspnFormula"
                    android:textColor="#006A7C"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:textColor="#006A7C"
                    android:id="@+id/textView4"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Obtener:"
                    android:textAlignment="center"
                    android:textSize="24sp" />

                <Spinner
                    android:spinnerMode="dropdown"
                    android:id="@+id/xspnObtener"
                    android:textColor="#006A7C"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout

            android:id="@+id/lLayout1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="25dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:visibility="invisible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txt1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TextView"
                    android:textColor="#006A7C"
                    android:textSize="24sp" />

                <EditText
                    android:id="@+id/xDato1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:focusable="auto"
                    android:focusableInTouchMode="false"
                    android:inputType="text"
                    android:textColor="#006A7C" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txt2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TextView"
                    android:textColor="#006A7C"
                    android:textSize="24sp" />

                <EditText
                    android:id="@+id/xDato2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:focusable="auto"
                    android:focusableInTouchMode="false"
                    android:inputType="text"
                    android:textColor="#006A7C" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txt3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TextView"
                    android:textColor="#006A7C"
                    android:textSize="24sp" />

                <EditText
                    android:id="@+id/xDato3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:focusable="auto"
                    android:focusableInTouchMode="false"
                    android:inputType="text"
                    android:textColor="#006A7C" />

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:orientation="vertical">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignParentBottom="true"
                android:layout_margin="16dp"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="0dp"
                android:columnCount="3"
                android:rowCount="6">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnSpan="3"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:textColor="#52A0C7"
                    android:text="Calcular"
                    android:id="@+id/xCalcular"
                    />

                <!-- Row 1 -->
                <Button
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:onClick="onDigit"
                    android:text="7"
                    android:textColor="#52A0C7" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:onClick="onDigit"
                    android:text="8"
                    android:textColor="#52A0C7" />

                <Button
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:onClick="onDigit"
                    android:text="9"
                    android:textColor="#52A0C7" />

                <!-- Row 2 -->
                <Button
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:onClick="onDigit"
                    android:text="4"
                    android:textColor="#52A0C7" />

                <Button
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:onClick="onDigit"
                    android:text="5"
                    android:textColor="#52A0C7" />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:onClick="onDigit"
                    android:text="6"
                    android:textColor="#52A0C7" />

                <!-- Row 3 -->
                <Button
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:onClick="onDigit"
                    android:text="1"
                    android:textColor="#52A0C7" />

                <Button
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:onClick="onDigit"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:textColor="#52A0C7"
                    android:text="2" />

                <Button
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:onClick="onDigit"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:textColor="#52A0C7"
                    android:text="3" />

                <!-- Row 4 -->
                <Button
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:onClick="onDigit"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:textColor="#52A0C7"
                    android:text="0" />

                <Button
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:onClick="onDigit"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:backgroundTint="#BADAE9"
                    android:textColor="#52A0C7"
                    android:text="." />

                <Button
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:onClick="onCE"
                    android:backgroundTint="#BADAE9"
                    android:textColor="#52A0C7"
                    android:text="x10" />

                <!-- Row 5 -->
                <Button
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnSpan="3"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:onClick="onClearButtonClick"
                    android:backgroundTint="#BADAE9"
                    android:textColor="#52A0C7"
                    android:text="C" />

            </GridLayout>
        </LinearLayout>


    </LinearLayout>

</RelativeLayout>