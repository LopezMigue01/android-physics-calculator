<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#DDE2E8"
    tools:context=".fragmentos.fr_Crear_Cuenta">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        >

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00789E"
            android:fontFamily="@font/capriola"
            android:textSize="24sp"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:text="Registrarse" />


        <LinearLayout
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:fontFamily="@font/capriola"
            android:textSize="16sp"
            android:text="Nombre"
            android:textColor="#52A0C7"
            />
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textInputLayout1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#52A0C7"
            android:textColorHint="#52A0C7"
            android:layout_marginStart="46dp"
            android:layout_marginEnd="20dp"
            android:hint="Nombre">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/xNomC"
                android:layout_width="match_parent"
                android:textColor="#C6A828"
                android:textColorHint="#C6A828"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:text="Boleta"
                android:textColor="#52A0C7"
                />
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#52A0C7"
                android:textColorHint="#52A0C7"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="20dp"
                android:hint="Boleta">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/xBolC"
                    android:layout_width="match_parent"
                    android:textColor="#C6A828"
                    android:textColorHint="#C6A828"
                    android:fontFamily="@font/capriola"
                    android:textSize="16sp"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView20"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:text="Grupo"
                android:textColor="#52A0C7"
                />
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout20"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#52A0C7"
                android:textColorHint="#52A0C7"
                android:layout_marginStart="63dp"
                android:layout_marginEnd="20dp"
                android:hint="Grupo">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/xGrupC"
                    android:layout_width="match_parent"
                    android:textColor="#C6A828"
                    android:textColorHint="#C6A828"
                    android:fontFamily="@font/capriola"
                    android:textSize="16sp"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView21"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:text="Turno"
                android:textColor="#52A0C7"
                />
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout21"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#52A0C7"
                android:textColorHint="#52A0C7"
                android:layout_marginStart="65dp"
                android:layout_marginEnd="20dp"
                android:hint="Turno">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/xTurC"
                    android:layout_width="match_parent"
                    android:textColor="#C6A828"
                    android:textColorHint="#C6A828"
                    android:fontFamily="@font/capriola"
                    android:textSize="16sp"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView22"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:text="Carrera"
                android:textColor="#52A0C7"
                />
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#52A0C7"
                android:textColorHint="#52A0C7"
                android:layout_marginStart="53dp"
                android:layout_marginEnd="20dp"
                android:hint="Carrera">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/xCarC"
                    android:layout_width="match_parent"
                    android:textColor="#C6A828"
                    android:textColorHint="#C6A828"
                    android:fontFamily="@font/capriola"
                    android:textSize="16sp"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textView11"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:textColor="#52A0C7"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:text="Celular" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="55dp"
                android:layout_marginEnd="20dp"
                android:hint="Numero Celular"
                android:textColor="#52A0C7"
                android:textColorHint="#52A0C7"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/xTelCelC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/capriola"
                    android:textColor="#52A0C7"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textView23"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:textColor="#52A0C7"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:text="Edad" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout23"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="72dp"
                android:layout_marginEnd="20dp"
                android:hint="Edad"
                android:textColor="#52A0C7"
                android:textColorHint="#52A0C7"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/xEdadC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/capriola"
                    android:textColor="#C6A828"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textView7"
                android:layout_marginStart="15dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#52A0C7"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:text="Correo" />
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout3"
                android:layout_marginStart="58dp"
                android:layout_marginEnd="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#52A0C7"
                android:textColorHint="#52A0C7"
                android:hint="Correo">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/xCorreoC"
                    android:textColor="#C6A828"
                    android:textColorHint="#C6A828"
                    android:fontFamily="@font/capriola"
                    android:textSize="16sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/textView8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:textColor="#52A0C7"
                android:fontFamily="@font/capriola"
                android:textSize="16sp"
                android:text="Contraseña" />
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:textColor="#52A0C7"
                android:textColorHint="#52A0C7"
                android:hint="Contraseña">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/xContraC"
                    android:textColor="#C6A828"
                    android:fontFamily="@font/capriola"
                    android:textSize="16sp"
                    android:inputType="text|textPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <Button
            android:id="@+id/xCrear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#BADAE9"
            android:textColor="#52A0C7"
            android:text="Crear Cuenta" />




    </LinearLayout>

</FrameLayout>