<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragmentos.fr_login_cuestionario">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DDE2E8"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="50dp"
            android:layout_marginTop="100dp"
            android:layout_marginEnd="50dp"
            android:gravity="center"
            android:text="Cuestionario"
            android:textColor="#C6A828"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/xIniciarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="150dp"
            android:backgroundTint="#BADAE9"
            android:textColor="#52A0C7"
            android:text="Iniciar Sesion" />

        <Button
            android:id="@+id/xCrearCuentafr"
            android:backgroundTint="#BADAE9"
            android:textColor="#52A0C7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Crear Cuenta" />
    </LinearLayout>
</FrameLayout>